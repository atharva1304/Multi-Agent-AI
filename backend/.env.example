# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/research_automation"

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Gemini
GEMINI_API_KEY=your-gemini-api-key

# Anthropic
